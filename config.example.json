  "quality": {
    "min_face_width": 70,
    "min_face_height": 70,
    "min_blur_score": 25.0,
    "min_detection_score": 0.1
  },
  "tracking": {
    "max_center_distance": 180,
    "max_missing_frames": 20
  },
  "cache": {
    "enabled": true,
    "path": "data/embeddings_cache.pkl",
    "force_rebuild": false
  },
  "logging": {
    "directory": "logs",
    "events_file": "recognition_events.csv"
  },
  "ui": {
    "window_name": "Biometric Access Control MVP",
    "show_fps": true
  }
